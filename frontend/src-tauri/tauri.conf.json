{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "db-auto-pilot",
  "version": "0.1.0",
  "identifier": "com.therealgo.dbautopilot",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "db-auto-pilot",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/db-auto-pilot-backend"
    ]
  }
}
